ORACLE_PASSWORD=
MOCK_EXTERNAL_APIS=true
ANTHROPIC_API_KEY=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === Scraper service (port 3211) ===
# Auth — Rails uses the SAME value to authenticate inbound from scraper
SCRAPER_API_TOKEN=

# 3-channel proxy (M9 50K). Empty proxy URL → channel disabled.
PROXY_RATIO=5:2.5:2.5
DECODO_PROXY_URL=
SMARTPROXY_URL=

# Worker pool + per-channel queue sizing
SCRAPER_PORT=3211
SCRAPER_WORKERS=3
DIRECT_BATCH_SIZE=500
DECODO_BATCH_SIZE=500
SMART_BATCH_SIZE=500
CHANNEL_BATCH_SIZE=500

# Browser session lifecycle
BROWSER_MAX_PAGES=3
SESSION_MAX_FETCHES=100
AMAZON_ZIP_CODE=90006

# Result buffer durability handoff to Rails
BATCH_RESULT_SIZE=50
BATCH_FLUSH_INTERVAL=30.0
RAILS_BATCH_ENDPOINT=http://localhost:3210/api/products/batch_upsert

# Memory watchdog — drain-restart workers when RSS exceeds this
WORKER_MEMORY_LIMIT_MB=

# === Legacy / deprecated ===
# PROXY_URL/LIST were the pre-M9 single-proxy knobs. Code no longer reads
# them; kept here only so existing .env files don't break grep/audits.
PROXY_URL=
PROXY_LIST=

# === Rate limiting (per-channel adaptive — see config.py) ===
AMAZON_DELAY_MIN=12
AMAZON_DELAY_MAX=25
AMAZON_DELAY_MEAN=18
AMAZON_DELAY_STDDEV=4
CATEGORY_PAUSE_MIN=180
CATEGORY_PAUSE_MAX=300
TRENDS_DELAY_MIN=6
TRENDS_DELAY_MAX=6
REDDIT_DELAY_MIN=1
REDDIT_DELAY_MAX=1
