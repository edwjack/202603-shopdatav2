<% content_for :page_title, "Collector Jobs" %>

<div class="space-y-8">
  <!-- Data Collectors (M4) -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Data Collectors</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Collector</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @collectors.each do |collector| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= collector[:name] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= collector[:schedule] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= button_to "Run Now",
                    run_jobs_path,
                    params: { job_class: collector[:job_class] },
                    method: :post,
                    class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500",
                    data: { turbo_confirm: "Enqueue #{collector[:name]}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- AI Analysis (M5) -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">AI Analysis</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @ai_jobs.each do |job| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job[:name] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job[:schedule] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= button_to "Run Now",
                    run_jobs_path,
                    params: { job_class: job[:job_class] },
                    method: :post,
                    class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500",
                    data: { turbo_confirm: "Enqueue #{job[:name]}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Sourcing Pipeline (M6) -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Sourcing Pipeline</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @sourcing_jobs.each do |job| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job[:name] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job[:schedule] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <% if job[:needs_category] %>
                <%= form_with url: run_jobs_path, method: :post, class: "inline-flex items-center gap-2", data: { turbo_confirm: "Run Sourcing Pipeline?" } do |f| %>
                  <%= f.hidden_field :job_class, value: job[:job_class] %>
                  <%= f.select :category_id, @categories.map { |c| [c.name, c.id] },
                        { prompt: "Select category..." },
                        class: "rounded-md border-gray-300 text-sm py-1.5 pr-8" %>
                  <%= f.submit "Run Now",
                        class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
                <% end %>
              <% else %>
                <%= button_to "Run Now",
                      run_jobs_path,
                      params: { job_class: job[:job_class] },
                      method: :post,
                      class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500",
                      data: { turbo_confirm: "Enqueue #{job[:name]}?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Sync Jobs (M6) -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Sync Jobs</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @sync_jobs.each do |job| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job[:name] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job[:schedule] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= button_to "Run Now",
                    run_jobs_path,
                    params: { job_class: job[:job_class] },
                    method: :post,
                    class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500",
                    data: { turbo_confirm: "Enqueue #{job[:name]}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Shopify Sync (M7) -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Shopify Sync</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @shopify_jobs.each do |job| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job[:name] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job[:schedule] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= button_to "Run Now",
                    run_jobs_path,
                    params: { job_class: job[:job_class] },
                    method: :post,
                    class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500",
                    data: { turbo_confirm: "Enqueue #{job[:name]}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Recent jobs table -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Job Executions</h2>
    </div>
    <% if @recent_jobs.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job Class</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Queue</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Enqueued At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Error</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_jobs.each do |job| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job.class_name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job.queue_name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job.created_at&.strftime("%Y-%m-%d %H:%M") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if @failed_job_ids[job.id] %>
                  <%= status_badge('failed') %>
                <% elsif job.finished_at %>
                  <%= status_badge('completed') %>
                <% else %>
                  <%= status_badge('pending') %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-red-600 max-w-xs truncate" title="<%= @failed_job_ids[job.id] %>">
                <%= @failed_job_ids[job.id]&.truncate(80) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-500">No recent job executions.</div>
    <% end %>
  </div>
</div>
