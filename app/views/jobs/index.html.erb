<% content_for :page_title, "Collector Jobs" %>

<div class="space-y-8">

  <!-- Data Collection -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Data Collection</h2>
      <span class="text-xs text-gray-400">On-demand — no schedule</span>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">Collector</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Run</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @collection_jobs.each do |job| %>
          <tr data-controller="job-runner"
              data-job-runner-job-class-value="<%= job[:job_class] %>"
              data-job-runner-url-value="<%= run_jobs_path %>">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= job[:name] %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if job[:last_at_key] %>
                <%
                  last_times = @categories.map { |c| c.send(job[:last_at_key]) rescue nil }.compact
                  last_at = last_times.max
                %>
                <% if last_at %>
                  <span title="<%= last_at.strftime('%Y-%m-%d %H:%M') %>">
                    Last: <%= time_ago_in_words(last_at) %> ago
                  </span>
                <% else %>
                  <span class="text-gray-400">Never</span>
                <% end %>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <div class="flex items-center gap-2 flex-wrap">
                <!-- Run All button -->
                <button type="button"
                        data-action="click->job-runner#runAll"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500">
                  Run All
                </button>
                <!-- Category dropdown + Run button -->
                <select data-job-runner-target="categorySelect"
                        data-action="change->job-runner#categoryChanged"
                        class="rounded-md border-gray-300 text-xs py-1.5 pr-8 max-w-xs">
                  <option value="">All categories</option>
                  <% @categories.each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
                <button type="button"
                        data-job-runner-target="runButton"
                        data-action="click->job-runner#run"
                        class="inline-flex items-center rounded-md bg-gray-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-gray-500">
                  Run
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Analysis -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Analysis</h2>
      <span class="text-xs text-gray-400">On-demand — no schedule</span>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Info</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @analysis_jobs.each do |job| %>
          <tr data-controller="job-runner"
              data-job-runner-job-class-value="<%= job[:job_class] %>"
              data-job-runner-url-value="<%= run_jobs_path %>">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= job[:name] %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <span class="text-gray-400">—</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <div class="flex items-center gap-2 flex-wrap">
                <button type="button"
                        data-action="click->job-runner#runAll"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500">
                  Run All
                </button>
                <select data-job-runner-target="categorySelect"
                        data-action="change->job-runner#categoryChanged"
                        class="rounded-md border-gray-300 text-xs py-1.5 pr-8 max-w-xs">
                  <option value="">All categories</option>
                  <% @categories.each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
                <button type="button"
                        data-job-runner-target="runButton"
                        data-action="click->job-runner#run"
                        class="inline-flex items-center rounded-md bg-gray-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-gray-500">
                  Run
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Sync -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Sync</h2>
      <span class="text-xs text-gray-400">On-demand — no schedule</span>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Info</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @sync_jobs.each do |job| %>
          <tr data-controller="job-runner"
              data-job-runner-job-class-value="<%= job[:job_class] %>"
              data-job-runner-url-value="<%= run_jobs_path %>">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= job[:name] %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <span class="text-gray-400">—</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <div class="flex items-center gap-2 flex-wrap">
                <button type="button"
                        data-action="click->job-runner#runAll"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500">
                  Run All
                </button>
                <select data-job-runner-target="categorySelect"
                        data-action="change->job-runner#categoryChanged"
                        class="rounded-md border-gray-300 text-xs py-1.5 pr-8 max-w-xs">
                  <option value="">All categories</option>
                  <% @categories.each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
                <button type="button"
                        data-job-runner-target="runButton"
                        data-action="click->job-runner#run"
                        class="inline-flex items-center rounded-md bg-gray-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-gray-500">
                  Run
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Infrastructure / Sourcing -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Infrastructure</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">Job</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Info</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @sourcing_jobs.each do |job| %>
          <tr data-controller="job-runner"
              data-job-runner-job-class-value="<%= job[:job_class] %>"
              data-job-runner-url-value="<%= run_jobs_path %>">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= job[:name] %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <span class="text-gray-400">Requires category</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <div class="flex items-center gap-2 flex-wrap">
                <select data-job-runner-target="categorySelect"
                        data-action="change->job-runner#categoryChanged"
                        class="rounded-md border-gray-300 text-xs py-1.5 pr-8 max-w-xs">
                  <option value="">Select category...</option>
                  <% @categories.each do |category| %>
                    <option value="<%= category.id %>"><%= category.name %></option>
                  <% end %>
                </select>
                <button type="button"
                        data-job-runner-target="runButton"
                        data-action="click->job-runner#run"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500">
                  Run
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Recent Job Executions -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Job Executions</h2>
    </div>
    <% if @recent_jobs.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job Class</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Queue</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Enqueued At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Error</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_jobs.each do |job| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= job.class_name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job.queue_name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= job.created_at&.strftime("%Y-%m-%d %H:%M") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if @failed_job_ids[job.id] %>
                  <%= status_badge('failed') %>
                <% elsif job.finished_at %>
                  <%= status_badge('completed') %>
                <% else %>
                  <%= status_badge('pending') %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-red-600 max-w-xs truncate" title="<%= @failed_job_ids[job.id] %>">
                <%= @failed_job_ids[job.id]&.truncate(80) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-500">No recent job executions.</div>
    <% end %>
  </div>

</div>
