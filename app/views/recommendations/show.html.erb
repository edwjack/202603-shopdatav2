<% content_for :page_title, "Recommendation Detail" %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Status & Score -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <div class="text-lg font-semibold text-gray-900"><%= @category&.name %></div>
          <div class="mt-1"><%= status_badge(@recommendation.status) %></div>
        </div>
        <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold <%= score_color(@recommendation.score) %>">
          <%= @recommendation.score %>
        </div>
      </div>
      <% if @recommendation.rejection_reason.present? %>
        <div class="mt-3 p-3 bg-red-50 rounded-md text-sm text-red-700">
          <span class="font-medium">Rejection reason:</span> <%= @recommendation.rejection_reason %>
        </div>
      <% end %>
    </div>

    <!-- Score breakdown -->
    <div class="bg-white shadow rounded-lg px-6 py-5" data-controller="score-chart">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Score Breakdown</h2>
      <% score_labels = {
           'demand_stability'      => '수요 안정성 (Demand Stability)',
           'growth_momentum'       => '성장 모멘텀 (Growth Momentum)',
           'competition_landscape' => '경쟁 환경 (Competition Landscape)',
           'margin_potential'      => '마진 잠재력 (Margin Potential)',
           'cs_risk'               => 'CS 리스크 (CS Risk)',
           'category_killer_fit'   => '카킬러 적합도 (Category Killer Fit)'
         } %>
      <% breakdown = @recommendation.score_breakdown_data %>
      <% score_labels.each do |key, label| %>
        <% val = breakdown[key] %>
        <% score_val = val.is_a?(Hash) ? val['score'].to_f : val.to_f %>
        <div class="mb-4">
          <div class="flex items-center justify-between text-sm mb-1">
            <span class="text-gray-700"><%= label %></span>
            <span class="font-bold text-gray-900"><%= score_val.round(1) %> / 10</span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-3">
            <div class="h-3 rounded-full transition-all"
                 data-score-chart-target="bar"
                 data-score="<%= score_val %>"></div>
          </div>
          <% if val.is_a?(Hash) && val['reason'].present? %>
            <div class="text-xs text-gray-500 mt-1"><%= val['reason'] %></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- AI Insight -->
    <% if @recommendation.insight.present? %>
      <div class="bg-white shadow rounded-lg px-6 py-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">AI Insight</h2>
        <p class="text-sm text-gray-700 leading-relaxed"><%= @recommendation.insight %></p>
      </div>
    <% end %>

    <!-- Risks -->
    <% risks = @recommendation.risks_data %>
    <% if risks.any? %>
      <div class="bg-white shadow rounded-lg px-6 py-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Risks</h2>
        <ul class="space-y-2">
          <% risks.each do |risk| %>
            <li class="flex items-start gap-2 text-sm text-red-700">
              <span class="mt-1 flex-shrink-0">&bull;</span>
              <%= risk %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Action Items -->
    <% actions = @recommendation.action_items_data %>
    <% if actions.any? %>
      <div class="bg-white shadow rounded-lg px-6 py-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Action Items</h2>
        <ul class="space-y-2">
          <% actions.each do |item| %>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="mt-0.5 flex-shrink-0 w-4 h-4 border border-gray-300 rounded"></span>
              <%= item %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Category info -->
    <% if @category %>
      <div class="bg-white shadow rounded-lg px-6 py-5">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Category</h2>
        <div class="space-y-2 text-sm">
          <div><span class="text-gray-500">Name:</span> <span class="font-medium"><%= @category.name %></span></div>
          <div><span class="text-gray-500">Status:</span> <%= status_badge(@category.status) %></div>
          <% if @category.risk_level.present? %>
            <div><span class="text-gray-500">Risk Level:</span> <span class="font-medium"><%= @category.risk_level %></span></div>
          <% end %>
          <% if @category.target_audience.present? %>
            <div><span class="text-gray-500">Audience:</span> <span class="font-medium"><%= @category.target_audience %></span></div>
          <% end %>
        </div>
        <div class="mt-3">
          <%= link_to "View Category", category_path(@category), class: "text-sm text-blue-600 hover:text-blue-500" %>
        </div>
      </div>
    <% end %>

    <!-- Metadata -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Metadata</h2>
      <div class="space-y-2 text-sm">
        <div><span class="text-gray-500">Created:</span> <span class="font-medium"><%= format_date(@recommendation.created_at) %></span></div>
        <div><span class="text-gray-500">Updated:</span> <span class="font-medium"><%= format_date(@recommendation.updated_at) %></span></div>
      </div>
    </div>

    <!-- Actions -->
    <% if @recommendation.status == 'pending' %>
      <div class="bg-white shadow rounded-lg px-6 py-5 space-y-3">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Actions</h2>
        <%= button_to "Approve", approve_recommendation_path(@recommendation), method: :patch,
              class: "w-full rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white hover:bg-green-500" %>
        <%= button_to "Put on Hold", hold_recommendation_path(@recommendation), method: :patch,
              class: "w-full rounded-md bg-gray-200 px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-300" %>
        <%= link_to "Back to List", recommendations_path, class: "block text-center text-sm text-gray-500 hover:text-gray-700 mt-2" %>
      </div>
    <% else %>
      <div class="mt-4">
        <%= link_to "Back to List", recommendations_path, class: "text-sm text-blue-600 hover:text-blue-500" %>
      </div>
    <% end %>
  </div>
</div>
