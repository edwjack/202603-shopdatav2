<!DOCTYPE html>
<html class="h-full bg-gray-50">
<head>
  <title><%= content_for(:title) || "ShopData" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full">
  <div class="min-h-full">
    <!-- Sidebar -->
    <nav class="fixed inset-y-0 left-0 w-64 bg-gray-900">
      <div class="flex h-16 items-center px-6">
        <span class="text-xl font-bold text-white">ShopData</span>
      </div>
      <ul class="mt-4 space-y-1 px-3">
        <%= sidebar_link "Dashboard", root_path, "home" %>
        <%= sidebar_link "Categories", categories_path, "folder" %>
        <%= sidebar_link "Recommendations", recommendations_path, "star" %>
        <%= sidebar_link "Products", products_path, "box" %>
        <%= sidebar_link "Jobs", jobs_path, "clock" %>
      </ul>
    </nav>

    <!-- Main content -->
    <div class="pl-64">
      <main class="py-6 px-8">
        <%= render "shared/flash" if flash.any? %>
        <% if content_for?(:page_title) %>
          <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= yield :page_title %></h1>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </div>
</body>
</html>
