<% content_for :page_title, @category.name %>

<div class="mb-4 text-sm text-gray-500">
  <%= link_to "Categories", categories_path, class: "text-blue-600 hover:text-blue-500" %>
  <span class="mx-1">/</span>
  <span class="text-gray-900 font-medium"><%= @category.name %></span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Header info -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <div class="flex items-start justify-between mb-3">
        <div>
          <%= status_badge(@category.status) %>
          <% if @category.risk_level.present? %>
            <span class="ml-2 text-sm text-gray-500">Risk: <span class="font-medium"><%= @category.risk_level %></span></span>
          <% end %>
        </div>
        <span class="text-xs text-gray-400"><%= format_date(@category.created_at) %></span>
      </div>
      <% if @category.description.present? %>
        <p class="text-sm text-gray-700"><%= @category.description %></p>
      <% end %>
      <% if @category.target_audience.present? %>
        <p class="mt-2 text-sm text-gray-500"><span class="font-medium">Target Audience:</span> <%= @category.target_audience %></p>
      <% end %>
    </div>

    <!-- Snapshot history -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Snapshot History (last 30)</h2>
      <% if @snapshots.empty? %>
        <p class="text-sm text-gray-500">No snapshots yet.</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 pr-4 text-xs text-gray-500 font-medium">Date</th>
                <th class="text-right py-2 pr-4 text-xs text-gray-500 font-medium">Avg BSR</th>
                <th class="text-right py-2 pr-4 text-xs text-gray-500 font-medium">BSR 7d</th>
                <th class="text-right py-2 pr-4 text-xs text-gray-500 font-medium">Trends</th>
                <th class="text-right py-2 text-xs text-gray-500 font-medium">Reddit</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @snapshots.each do |snap| %>
                <tr>
                  <td class="py-2 pr-4 text-gray-700"><%= snap.snapshot_date&.strftime("%Y-%m-%d") %></td>
                  <td class="py-2 pr-4 text-right text-gray-700"><%= snap.avg_bsr&.to_s(:delimited) rescue snap.avg_bsr %></td>
                  <td class="py-2 pr-4 text-right <%= snap.bsr_7d_change.to_f < 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= snap.bsr_7d_change.present? ? "#{snap.bsr_7d_change > 0 ? '+' : ''}#{snap.bsr_7d_change}%" : '-' %>
                  </td>
                  <td class="py-2 pr-4 text-right text-gray-700"><%= snap.trends_interest || '-' %></td>
                  <td class="py-2 text-right text-gray-700"><%= snap.reddit_mentions || '-' %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>

    <!-- Example Products (from JSON column) -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Example Products</h2>
      <%
        example_products = begin
          @category.example_products.present? ? JSON.parse(@category.example_products) : []
        rescue JSON::ParserError, TypeError
          []
        end
      %>
      <% if example_products.empty? %>
        <p class="text-sm text-gray-500">No example products defined.</p>
      <% else %>
        <ul class="space-y-2">
          <% example_products.each do |ep| %>
            <li class="flex items-center gap-3 text-sm">
              <% if ep.is_a?(Hash) %>
                <span class="font-mono text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded"><%= ep['asin'] %></span>
                <span class="text-gray-700"><%= ep['title'] %></span>
                <% if ep['price'] %>
                  <span class="ml-auto text-gray-500">$<%= ep['price'] %></span>
                <% end %>
              <% else %>
                <span class="text-gray-700"><%= ep %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <!-- Linked Recommendations -->
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-4">Recommendations</h2>
      <% if @recommendations.empty? %>
        <p class="text-sm text-gray-500">No recommendations yet.</p>
      <% else %>
        <ul class="divide-y divide-gray-100">
          <% @recommendations.each do |rec| %>
            <li class="py-3 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold <%= score_color(rec.score) %>">
                  <%= rec.score %>
                </span>
                <%= status_badge(rec.status) %>
                <span class="text-xs text-gray-400"><%= format_date(rec.created_at) %></span>
              </div>
              <%= link_to "View", recommendation_path(rec), class: "text-sm text-blue-600 hover:text-blue-500" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Summary</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Slug</dt>
          <dd class="font-mono text-gray-700"><%= @category.slug %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Recommendations</dt>
          <dd class="font-medium text-gray-900"><%= @recommendations.size %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Products</dt>
          <dd class="font-medium text-gray-900"><%= @products_count %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Snapshots</dt>
          <dd class="font-medium text-gray-900"><%= @snapshots.size %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Shopify Settings</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Margin Rate</dt>
          <dd class="font-medium text-gray-900"><%= @category.margin_rate || 50.0 %>%</dd>
        </div>
      </dl>
      <div class="mt-3">
        <%= link_to "Edit Settings", edit_category_path(@category), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
      </div>
    </div>

    <div class="bg-white shadow rounded-lg px-6 py-5">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">Quick Links</h2>
      <%= link_to "All Products in Category", products_path(category_id: @category.id), class: "block text-sm text-blue-600 hover:text-blue-500 mb-2" %>
      <%= link_to "Back to Categories", categories_path, class: "block text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  </div>
</div>
