<nav class="flex items-center justify-between py-3">
  <div class="flex items-center gap-2">
    <% if @total_pages && @total_pages > 1 && @page > 1 %>
      <%= link_to "First", url_for(page: 1), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <% end %>
    <% if @page > 1 %>
      <%= link_to "Previous", url_for(page: @page - 1), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <% else %>
      <span></span>
    <% end %>
  </div>
  <span class="text-sm text-gray-700">
    Page <%= @page %><% if @total_pages %> of <%= @total_pages %><% end %><% if @total %> (<%= @total %> total)<% end %>
  </span>
  <div class="flex items-center gap-2">
    <% if @has_next %>
      <%= link_to "Next", url_for(page: @page + 1), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <% else %>
      <span></span>
    <% end %>
    <% if @total_pages && @total_pages > 1 && @page < @total_pages %>
      <%= link_to "Last", url_for(page: @total_pages), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <% end %>
  </div>
</nav>
