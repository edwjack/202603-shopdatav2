<%# Niche Suggestion Modal
    Locals:
      suggestions  - Array of hashes from NicheRefinementService.suggest(category)
      category     - The parent Category record
%>
<turbo-frame id="niche_suggestion_modal">
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
       data-controller="modal"
       data-action="click->modal#closeOnBackdrop keydown.esc@window->modal#close">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden"
         data-modal-target="panel">

      <%# Header %>
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Niche Sub-Category Suggestions</h2>
          <p class="text-sm text-gray-500 mt-0.5">Based on <span class="font-medium"><%= category.name %></span></p>
        </div>
        <%= link_to "×",
              request.path,
              data: { turbo_frame: "niche_suggestion_modal" },
              class: "text-gray-400 hover:text-gray-600 text-2xl leading-none font-light" %>
      </div>

      <%# Suggestion list %>
      <div class="divide-y divide-gray-100 max-h-[60vh] overflow-y-auto">
        <% suggestions.each do |suggestion| %>
          <div class="px-6 py-4 hover:bg-gray-50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <%# Name + competition badge %>
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-sm font-semibold text-gray-900"><%= suggestion['name'] %></h3>
                  <%
                    competition = suggestion['estimated_competition']
                    badge_css = case competition
                                when 'low'    then 'bg-green-100 text-green-700'
                                when 'medium' then 'bg-yellow-100 text-yellow-700'
                                when 'high'   then 'bg-red-100 text-red-700'
                                else               'bg-gray-100 text-gray-600'
                                end
                  %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= badge_css %>">
                    <%= competition&.capitalize %> competition
                  </span>
                  <% if suggestion['target_price_range'].present? %>
                    <span class="text-xs text-gray-500"><%= suggestion['target_price_range'] %></span>
                  <% end %>
                </div>

                <%# Rationale %>
                <p class="mt-1 text-sm text-gray-600"><%= suggestion['rationale'] %></p>
              </div>

              <%# Select button — creates new Category and redirects to jobs page %>
              <%= button_to "Select",
                    categories_path,
                    method: :post,
                    params: {
                      category: {
                        name: suggestion['name'],
                        slug: suggestion['slug'],
                        parent_id: category.id
                      },
                      redirect_to: jobs_path
                    },
                    class: "shrink-0 inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-lg
                            bg-indigo-600 text-white hover:bg-indigo-700 focus:outline-none
                            focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1 transition-colors" %>
            </div>
          </div>
        <% end %>

        <% if suggestions.blank? %>
          <div class="px-6 py-8 text-center text-gray-500 text-sm">
            No suggestions available. Try again later.
          </div>
        <% end %>
      </div>

      <%# Footer %>
      <div class="px-6 py-3 bg-gray-50 border-t border-gray-200 flex justify-end">
        <%= link_to "Cancel",
              request.path,
              data: { turbo_frame: "niche_suggestion_modal" },
              class: "text-sm text-gray-600 hover:text-gray-800 font-medium" %>
      </div>

    </div>
  </div>
</turbo-frame>
