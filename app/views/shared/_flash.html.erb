<% flash.each do |type, message| %>
  <% css = type.to_s == 'notice' ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800' %>
  <div data-controller="flash"
       class="mb-4 rounded-md border px-4 py-3 flex items-center justify-between <%= css %>">
    <span><%= message %></span>
    <button data-action="click->flash#dismiss" class="ml-4 text-current opacity-60 hover:opacity-100 text-lg leading-none">&times;</button>
  </div>
<% end %>
