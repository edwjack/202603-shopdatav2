<% content_for :page_title, "Products" %>

<!-- Search + filters -->
<div class="mb-6 flex flex-wrap gap-3 items-center">
  <%= form_with url: products_path, method: :get, data: { controller: "search", turbo_frame: "_top" } do |f| %>
    <div class="relative">
      <%= f.text_field :q,
            value: params[:q],
            placeholder: "Search by title or ASIN...",
            class: "block w-72 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm pl-3 pr-10 py-2",
            data: { action: "input->search#debounce", search_target: "input" } %>
    </div>
    <%= f.select :status,
          options_for_select([
            ['All Sourcing', ''],
            ['Pending', 'pending'],
            ['Approved', 'approved'],
            ['Rejected', 'rejected']
          ], params[:status]),
          {},
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2" %>
    <%= f.select :shopify_status,
          options_for_select([
            ['All Shopify', ''],
            ['Pending', 'pending'],
            ['Publishing', 'publishing'],
            ['Published', 'published'],
            ['Failed', 'failed']
          ], params[:shopify_status]),
          {},
          class: "rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2" %>
    <%= f.submit "Filter", class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 cursor-pointer" %>
    <% if params[:q].present? || params[:status].present? || params[:shopify_status].present? %>
      <%= link_to "Clear", products_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <% end %>
  <% end %>
</div>

<!-- Batch publish form -->
<%= form_with url: batch_publish_shopify_products_path, method: :post, data: { controller: "batch-publish", turbo_confirm: "Publish selected products to Shopify?" } do |f| %>
  <div class="mb-3 flex items-center gap-3" data-batch-publish-target="toolbar" style="display:none;">
    <span class="text-sm text-gray-600" data-batch-publish-target="count">0 selected</span>
    <%= f.submit "Publish Selected to Shopify",
          class: "rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 cursor-pointer" %>
  </div>

  <!-- Products table -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left">
            <input type="checkbox" data-action="change->batch-publish#toggleAll" data-batch-publish-target="selectAll"
                   class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
          </th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ASIN</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Brand</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sourcing</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shopify</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if @products.empty? %>
          <tr>
            <td colspan="8" class="px-6 py-8 text-center text-gray-500">No products found.</td>
          </tr>
        <% else %>
          <% @products.each do |product| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-4">
                <% if product.sourcing_status == 'approved' && product.scraper_status == 'completed' && product.shopify_status != 'publishing' %>
                  <input type="checkbox" name="product_ids[]" value="<%= product.id %>"
                         data-action="change->batch-publish#updateCount" data-batch-publish-target="checkbox"
                         class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="font-mono text-xs text-gray-600 bg-gray-100 px-2 py-1 rounded"><%= product.asin %></span>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm text-gray-900 max-w-xs truncate"><%= product.title || "-" %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= product.brand || "-" %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900">
                <%= product.price ? "$#{product.price}" : "-" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(product.sourcing_status || 'pending') %></td>
              <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(product.shopify_status || 'pending') %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <%= link_to "View", product_path(product), class: "text-sm text-blue-600 hover:text-blue-500" %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "shared/pagination" %>
